{
  "name": "@neoark/cite",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0",
  "description": "Tiny embeddable SDK — auto-publish use-proofs when NeoOS verses are rendered",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "bundle": "esbuild src/browser.ts --bundle --minify --format=iife --global-name=NeoArkCite --outfile=dist/cite.min.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "esbuild": "^0.21.5",
    "jsdom": "^24.0.0",
    "tsx": "^4.16.0",
    "vitest": "^1.6.0"
  }
}
