{
  "name": "neoark",
  "private": true,
  "version": "0.0.1",
  "description": "NeoArk — Open peer-to-peer Bible translation protocol",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint 'packages/**/*.ts' 'apps/**/*.ts' 'tools/**/*.ts' --max-warnings 0 --no-error-on-unmatched-pattern",
    "lint:fix": "eslint 'packages/**/*.ts' 'apps/**/*.ts' 'tools/**/*.ts' --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "build:apps": "node scripts/split-corpus.mjs && pnpm --filter @neoark/landing build && BASE_PATH=/read pnpm --filter @neoark/reader-pwa build && BASE_PATH=/translate pnpm --filter translator build",
    "build:site": "pnpm run build:apps && node scripts/build-site.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
